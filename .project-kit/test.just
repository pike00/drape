# .project-kit/test.just — generated for drape (python)
# Generated by project-kit (skill version: 0.1.0)
# Last refreshed: 2026-06-06

# Run all configured test layers in order
test: test-all

test-all:
    @just lint
    @just typecheck
    @just test-backend
    @just test-frontend
    @just test-e2e

test-backend:
    @uv run pytest

test-frontend:
    @just _skip "frontend tests"

test-e2e:
    @just _skip "e2e tests"

test-watch:
    @uv run pytest -f

lint:
    @uv run ruff check . && uv run black --check .

typecheck:
    @uv run mypy src/drape
