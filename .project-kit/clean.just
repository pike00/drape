# .project-kit/clean.just — generated for drape (python)
# Generated by project-kit (skill version: 0.1.0)
# Last refreshed: 2026-06-06

clean:
    @rm -rf dist/ build/ .pytest_cache/ .ruff_cache/ .mypy_cache/
    @find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    @echo "[clean] artifacts removed"

clean-all:
    @just clean
    @rm -rf .venv/ .uv-cache/
    @echo "[clean-all] deep clean complete"

clean-docker:
    @just _skip "clean-docker"
